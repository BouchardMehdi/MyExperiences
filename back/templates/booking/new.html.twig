{% extends 'base.html.twig' %}

{% block title %}Réserver un créneau | MyExperiences{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <section class="card app-card">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="h3 mb-3">Réserver un créneau</h1>
                    <p class="text-muted">Expérience : <strong>{{ slot.experience.title }}</strong></p>
                    <p class="text-muted">Créneau : {{ slot.startAt|date('d/m/Y H:i') }} - {{ slot.endAt|date('H:i') }}</p>
                    <p class="text-muted">Places restantes : {{ slot.remainingPlaces }}</p>

                    {{ form_start(bookingForm) }}
                        {{ form_row(bookingForm.seats) }}
                        <button class="btn btn-primary" type="submit">Confirmer la réservation</button>
                    {{ form_end(bookingForm) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
