{% extends 'base.html.twig' %}

{% block title %}Mes expériences | MyExperiences{% endblock %}

{% block body %}
    <section class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-1">Mes expériences</h1>
            <p class="text-muted mb-0">Créez, modifiez et publiez vos activités.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_organizer_experience_new') }}">Nouvelle expérience</a>
    </section>

    <div class="row g-4">
        {% for experience in experiences %}
            <div class="col-lg-6">
                <div class="card app-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between gap-3 mb-3">
                            <div>
                                <h2 class="h5 mb-1">{{ experience.title }}</h2>
                                <p class="text-muted mb-0">{{ experience.location }} • {{ experience.duration }} min</p>
                            </div>
                            <span class="badge text-bg-secondary">{{ experience.status.label }}</span>
                        </div>
                        <p class="text-muted">{{ experience.description|length > 120 ? experience.description|slice(0, 120) ~ '...' : experience.description }}</p>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_organizer_experience_edit', {id: experience.id}) }}">Modifier</a>
                            <a class="btn btn-sm btn-outline-dark" href="{{ path('app_organizer_slot_index', {id: experience.id}) }}">Gérer les créneaux</a>
                            <form method="post" action="{{ path('app_organizer_experience_delete', {id: experience.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_experience_' ~ experience.id) }}">
                                <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12"><div class="alert alert-light border">Aucune expérience créée pour le moment.</div></div>
        {% endfor %}
    </div>
{% endblock %}
