{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }} | MyExperiences{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <section class="card app-card">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="h3 mb-4">{{ pageTitle }}</h1>
                    {{ form_start(form) }}
                        <div class="row g-3">
                            <div class="col-12">{{ form_row(form.title) }}</div>
                            <div class="col-md-6">{{ form_row(form.location) }}</div>
                            <div class="col-md-3">{{ form_row(form.price) }}</div>
                            <div class="col-md-3">{{ form_row(form.duration) }}</div>
                            <div class="col-12">{{ form_row(form.description) }}</div>
                            <div class="col-md-4">{{ form_row(form.status) }}</div>
                        </div>
                        <button class="btn btn-primary mt-4" type="submit">Enregistrer</button>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
