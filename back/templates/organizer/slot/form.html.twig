{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }} | MyExperiences{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <section class="card app-card">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="h3 mb-3">{{ pageTitle }}</h1>
                    <p class="text-muted">Expérience : {{ experience.title }}</p>
                    {{ form_start(form) }}
                        <div class="row g-3">
                            <div class="col-md-6">{{ form_row(form.startAt) }}</div>
                            <div class="col-md-6">{{ form_row(form.endAt) }}</div>
                            <div class="col-md-6">{{ form_row(form.capacity) }}</div>
                            <div class="col-md-6 d-flex align-items-end">{{ form_row(form.isActive) }}</div>
                        </div>
                        <button class="btn btn-primary mt-4" type="submit">Enregistrer</button>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
