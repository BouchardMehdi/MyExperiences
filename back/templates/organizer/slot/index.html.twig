{% extends 'base.html.twig' %}

{% block title %}Créneaux | MyExperiences{% endblock %}

{% block body %}
    <section class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-1">Créneaux de {{ experience.title }}</h1>
            <p class="text-muted mb-0">Gérez les dates, capacités et disponibilités.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_organizer_slot_new', {id: experience.id}) }}">Ajouter un créneau</a>
    </section>

    <section class="card app-card">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Début</th>
                            <th>Fin</th>
                            <th>Capacité</th>
                            <th>Restantes</th>
                            <th>Actif</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for slot in experience.slots %}
                            <tr>
                                <td>{{ slot.startAt|date('d/m/Y H:i') }}</td>
                                <td>{{ slot.endAt|date('d/m/Y H:i') }}</td>
                                <td>{{ slot.capacity }}</td>
                                <td>{{ slot.remainingPlaces }}</td>
                                <td>{{ slot.isActive ? 'Oui' : 'Non' }}</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_organizer_slot_edit', {id: slot.id}) }}">Modifier</a>
                                        <form method="post" action="{{ path('app_organizer_slot_delete', {id: slot.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_slot_' ~ slot.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="6" class="text-muted">Aucun créneau pour cette expérience.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
