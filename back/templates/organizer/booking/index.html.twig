{% extends 'base.html.twig' %}

{% block title %}Réservations organisateur | MyExperiences{% endblock %}

{% block body %}
    <section class="mb-4">
        <h1 class="section-title mb-1">Réservations reçues</h1>
        <p class="text-muted mb-0">Vue centralisée des réservations liées à vos expériences.</p>
    </section>

    <section class="card app-card">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Expérience</th>
                            <th>Participant</th>
                            <th>Créneau</th>
                            <th>Places</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for booking in bookings %}
                            <tr>
                                <td>{{ booking.slot.experience.title }}</td>
                                <td>{{ booking.user.fullName }}</td>
                                <td>{{ booking.slot.startAt|date('d/m/Y H:i') }}</td>
                                <td>{{ booking.seats }}</td>
                                <td>{{ booking.status.label }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-muted">Aucune réservation reçue.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
