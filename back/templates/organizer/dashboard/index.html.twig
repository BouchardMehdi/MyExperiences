{% extends 'base.html.twig' %}

{% block title %}Dashboard organisateur | MyExperiences{% endblock %}

{% block body %}
    <section class="mb-4">
        <h1 class="section-title mb-1">Dashboard organisateur</h1>
        <p class="text-muted mb-0">Pilotez vos expériences, créneaux et réservations.</p>
    </section>

    <section class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Expériences</div><div class="fs-2 fw-bold">{{ stats.experiences }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Publiées</div><div class="fs-2 fw-bold">{{ stats.published }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Créneaux</div><div class="fs-2 fw-bold">{{ stats.slots }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Réservations</div><div class="fs-2 fw-bold">{{ stats.bookings }}</div></div></div>
    </section>

    <section class="card app-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h4 mb-0">Réservations récentes</h2>
                <a class="btn btn-outline-primary btn-sm" href="{{ path('app_organizer_booking_index') }}">Voir tout</a>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Expérience</th>
                            <th>Participant</th>
                            <th>Créneau</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for booking in recentBookings %}
                            <tr>
                                <td>{{ booking.slot.experience.title }}</td>
                                <td>{{ booking.user.fullName }}</td>
                                <td>{{ booking.slot.startAt|date('d/m/Y H:i') }}</td>
                                <td>{{ booking.status.label }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-muted">Aucune réservation pour le moment.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
