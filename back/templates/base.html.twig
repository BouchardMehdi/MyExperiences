<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}MyExperiences{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221em%22 font-size=%2290%22>ME</text></svg>">
        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet">
            <style>
                body { font-family: 'Manrope', sans-serif; }
            </style>
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" defer></script>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
            <div class="container py-2">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">MyExperiences</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Basculer la navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_experience_index') }}">Expériences</a></li>
                        {% if is_granted('ROLE_USER') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_dashboard') }}">Mon espace</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_booking_index') }}">Mes réservations</a></li>
                        {% endif %}
                        {% if is_granted('ROLE_ORGANIZER') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_organizer_dashboard') }}">Espace organisateur</a></li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_dashboard') }}">Admin</a></li>
                        {% endif %}
                    </ul>
                    <div class="d-flex gap-2 align-items-center">
                        {% if app.user %}
                            <span class="text-muted small">{{ app.user.fullName }}</span>
                            <a class="btn btn-outline-dark btn-sm" href="{{ path('app_logout') }}">Se déconnecter</a>
                        {% else %}
                            <a class="btn btn-outline-dark btn-sm" href="{{ path('app_login') }}">Connexion</a>
                            <a class="btn btn-primary btn-sm" href="{{ path('app_register') }}">Inscription</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <main class="py-4 py-lg-5">
            <div class="container">
                {% include 'partials/_flash.html.twig' %}
                {% block body %}{% endblock %}
            </div>
        </main>
    </body>
</html>
