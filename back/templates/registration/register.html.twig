{% extends 'base.html.twig' %}

{% block title %}Inscription | MyExperiences{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <section class="card app-card">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="h3 mb-4">Créer un compte</h1>
                    {{ form_start(registrationForm) }}
                        <div class="row g-3">
                            <div class="col-md-6">{{ form_row(registrationForm.firstname) }}</div>
                            <div class="col-md-6">{{ form_row(registrationForm.lastname) }}</div>
                            <div class="col-12">{{ form_row(registrationForm.email) }}</div>
                            <div class="col-md-6">{{ form_row(registrationForm.plainPassword.first) }}</div>
                            <div class="col-md-6">{{ form_row(registrationForm.plainPassword.second) }}</div>
                        </div>
                        <button class="btn btn-primary mt-4" type="submit">Créer mon compte</button>
                    {{ form_end(registrationForm) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
