{% extends 'base.html.twig' %}

{% block title %}Modifier un utilisateur | MyExperiences{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <section class="card app-card">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="h3 mb-3">Modifier les rôles</h1>
                    <p class="text-muted">{{ userItem.fullName }} • {{ userItem.email }}</p>
                    {{ form_start(form) }}
                        {{ form_row(form.roles) }}
                        <button class="btn btn-primary" type="submit">Enregistrer</button>
                    {{ form_end(form) }}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
