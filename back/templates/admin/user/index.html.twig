{% extends 'base.html.twig' %}

{% block title %}Utilisateurs | MyExperiences{% endblock %}

{% block body %}
    <section class="mb-4">
        <h1 class="section-title mb-1">Gestion des utilisateurs</h1>
        <p class="text-muted mb-0">Ajustez les rôles et la gouvernance de la plateforme.</p>
    </section>

    <section class="card app-card">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôles</th>
                            <th>Créé le</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>{{ user.fullName }}</td>
                                <td>{{ user.email }}</td>
                                <td>{{ user.roles|join(', ') }}</td>
                                <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                                <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_user_edit', {id: user.id}) }}">Modifier</a></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-muted">Aucun utilisateur.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
