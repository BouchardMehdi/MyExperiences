{% extends 'base.html.twig' %}

{% block title %}Dashboard admin | MyExperiences{% endblock %}

{% block body %}
    <section class="mb-4">
        <h1 class="section-title mb-1">Administration</h1>
        <p class="text-muted mb-0">Supervisez utilisateurs, expériences, réservations et avis.</p>
    </section>

    <section class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Utilisateurs</div><div class="fs-2 fw-bold">{{ stats.users }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Expériences</div><div class="fs-2 fw-bold">{{ stats.experiences }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Réservations</div><div class="fs-2 fw-bold">{{ stats.bookings }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Avis</div><div class="fs-2 fw-bold">{{ stats.reviews }}</div></div></div>
    </section>

    <div class="d-flex flex-wrap gap-3">
        <a class="btn btn-outline-primary" href="{{ path('app_admin_user_index') }}">Gérer les utilisateurs</a>
        <a class="btn btn-outline-primary" href="{{ path('app_admin_experience_index') }}">Gérer les expériences</a>
        <a class="btn btn-outline-primary" href="{{ path('app_admin_review_index') }}">Modérer les avis</a>
    </div>
{% endblock %}
