{% extends 'base.html.twig' %}

{% block title %}Expériences admin | MyExperiences{% endblock %}

{% block body %}
    <section class="mb-4">
        <h1 class="section-title mb-1">Gestion des expériences</h1>
        <p class="text-muted mb-0">Revoir les contenus publiés et ajuster leur statut.</p>
    </section>

    <section class="card app-card">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Organisateur</th>
                            <th>Lieu</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for experience in experiences %}
                            <tr>
                                <td>{{ experience.title }}</td>
                                <td>{{ experience.organizer.fullName }}</td>
                                <td>{{ experience.location }}</td>
                                <td>{{ experience.status.label }}</td>
                                <td class="text-end">
                                    <div class="d-flex flex-wrap justify-content-end gap-2">
                                        <form method="post" action="{{ path('app_admin_experience_status', {id: experience.id, status: 'PUBLISHED'}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_experience_status_' ~ experience.id) }}">
                                            <button class="btn btn-sm btn-outline-success" type="submit">Publier</button>
                                        </form>
                                        <form method="post" action="{{ path('app_admin_experience_status', {id: experience.id, status: 'ARCHIVED'}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_experience_status_' ~ experience.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Archiver</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-muted">Aucune expérience.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
