{% extends 'base.html.twig' %}

{% block title %}Mon tableau de bord | MyExperiences{% endblock %}

{% block body %}
    <section class="mb-4">
        <h1 class="section-title mb-1">Mon tableau de bord</h1>
        <p class="text-muted mb-0">Suivez vos réservations, paiements mock et avis.</p>
    </section>

    <section class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Réservations</div><div class="fs-2 fw-bold">{{ stats.totalBookings }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Payées</div><div class="fs-2 fw-bold">{{ stats.paidBookings }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">En attente</div><div class="fs-2 fw-bold">{{ stats.pendingBookings }}</div></div></div>
        <div class="col-md-6 col-xl-3"><div class="metric-card p-4"><div class="text-muted small">Avis publiés</div><div class="fs-2 fw-bold">{{ stats.reviews }}</div></div></div>
    </section>

    <section class="card app-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h4 mb-0">Dernières réservations</h2>
                <a class="btn btn-outline-primary btn-sm" href="{{ path('app_booking_index') }}">Voir tout</a>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Expérience</th>
                            <th>Date</th>
                            <th>Statut</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for booking in bookings %}
                            <tr>
                                <td>{{ booking.slot.experience.title }}</td>
                                <td>{{ booking.slot.startAt|date('d/m/Y H:i') }}</td>
                                <td>{{ booking.status.label }}</td>
                                <td>{{ booking.totalPrice|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-muted">Aucune réservation pour le moment.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
