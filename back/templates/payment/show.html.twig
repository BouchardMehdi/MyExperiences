{% extends 'base.html.twig' %}

{% block title %}Paiement mock | MyExperiences{% endblock %}

{% block body %}
    <div id="paymentLoader" class="payment-loader">
        <div class="bg-white rounded-4 shadow p-4 text-center">
            <div class="spinner-border text-primary mb-3" role="status"></div>
            <p class="mb-0">Simulation du paiement en cours...</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <section class="card app-card">
                <div class="card-body p-4 p-lg-5">
                    <span class="badge text-bg-dark mb-3">Paiement mock</span>
                    <h1 class="h3 mb-3">Simulation de paiement</h1>
                    <p class="text-muted">Aucune carte bancaire n’est demandée. Cette étape sert à démontrer le workflow métier.</p>

                    <dl class="row">
                        <dt class="col-sm-4">Expérience</dt>
                        <dd class="col-sm-8">{{ booking.slot.experience.title }}</dd>
                        <dt class="col-sm-4">Créneau</dt>
                        <dd class="col-sm-8">{{ booking.slot.startAt|date('d/m/Y H:i') }}</dd>
                        <dt class="col-sm-4">Places</dt>
                        <dd class="col-sm-8">{{ booking.seats }}</dd>
                        <dt class="col-sm-4">Montant</dt>
                        <dd class="col-sm-8 fw-semibold">{{ booking.totalPrice|number_format(2, ',', ' ') }} €</dd>
                    </dl>

                    <div class="d-flex flex-column flex-md-row gap-3 mt-4">
                        <form class="payment-action" method="post" action="{{ path('app_payment_success', {id: booking.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('payment_success_' ~ booking.id) }}">
                            <button class="btn btn-success btn-lg" type="submit">Simuler succès</button>
                        </form>
                        <form class="payment-action" method="post" action="{{ path('app_payment_failure', {id: booking.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('payment_failure_' ~ booking.id) }}">
                            <button class="btn btn-outline-danger btn-lg" type="submit">Simuler échec</button>
                        </form>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script>
        document.querySelectorAll('.payment-action').forEach((form) => {
            form.addEventListener('submit', () => {
                document.getElementById('paymentLoader').classList.add('is-visible');
            });
        });
    </script>
{% endblock %}
