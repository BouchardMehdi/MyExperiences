{% extends 'base.html.twig' %}

{% block title %}{{ experience.title }} | MyExperiences{% endblock %}

{% block body %}
    <div class="row g-4">
        <div class="col-lg-8">
            <section class="card app-card mb-4">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                        <div>
                            <span class="badge badge-soft mb-2">{{ experience.location }}</span>
                            <h1 class="mb-1">{{ experience.title }}</h1>
                            <p class="text-muted mb-0">Organisé par {{ experience.organizer.fullName }}</p>
                        </div>
                        <div class="text-lg-end">
                            <div class="fs-4 fw-bold text-primary">{{ experience.price|number_format(2, ',', ' ') }} €</div>
                            <div class="text-muted">{{ experience.duration }} minutes</div>
                        </div>
                    </div>
                    <p class="mb-0">{{ experience.description }}</p>
                </div>
            </section>

            <section class="card app-card mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h4 mb-0">Créneaux disponibles</h2>
                        {% if not app.user %}
                            <a class="btn btn-sm btn-outline-dark" href="{{ path('app_login') }}">Se connecter pour réserver</a>
                        {% endif %}
                    </div>

                    <div class="row g-3">
                        {% for slot in slots %}
                            <div class="col-12">
                                <div class="border rounded-4 p-3 d-flex flex-column flex-md-row justify-content-between gap-3">
                                    <div>
                                        <div class="fw-semibold">{{ slot.startAt|date('d/m/Y H:i') }} - {{ slot.endAt|date('H:i') }}</div>
                                        <div class="text-muted small">{{ slot.remainingPlaces }} place(s) restante(s) sur {{ slot.capacity }}</div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        {% if is_granted('ROLE_USER') %}
                                            <a class="btn btn-primary btn-sm" href="{{ path('app_booking_new', {id: slot.id}) }}">Réserver</a>
                                        {% else %}
                                            <span class="text-muted small">Connexion requise</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="col-12">
                                <div class="alert alert-light border mb-0">Aucun créneau réservable pour le moment.</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="card app-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 mb-3">Infos clés</h2>
                    <dl class="row mb-0">
                        <dt class="col-6 text-muted">Lieu</dt>
                        <dd class="col-6">{{ experience.location }}</dd>
                        <dt class="col-6 text-muted">Durée</dt>
                        <dd class="col-6">{{ experience.duration }} min</dd>
                        <dt class="col-6 text-muted">Note moyenne</dt>
                        <dd class="col-6">
                            {% if experience.averageRating is not null %}
                                {{ experience.averageRating }}/5
                            {% else %}
                                Pas encore d’avis
                            {% endif %}
                        </dd>
                    </dl>
                </div>
            </section>

            <section class="card app-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Avis récents</h2>
                        {% if canReview %}
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_review_new', {id: experience.id}) }}">Laisser un avis</a>
                        {% endif %}
                    </div>

                    {% for review in reviews %}
                        <article class="{{ loop.first ? '' : 'border-top pt-3 mt-3' }}">
                            <div class="d-flex justify-content-between gap-2 mb-2">
                                <strong>{{ review.user.fullName }}</strong>
                                <span class="text-warning">{{ review.rating }}/5</span>
                            </div>
                            <p class="small text-muted mb-2">{{ review.createdAt|date('d/m/Y') }}</p>
                            <p class="mb-0">{{ review.comment }}</p>
                        </article>
                    {% else %}
                        <p class="text-muted mb-0">Aucun avis pour le moment.</p>
                    {% endfor %}
                </div>
            </section>
        </div>
    </div>
{% endblock %}
