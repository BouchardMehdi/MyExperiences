{% extends 'base.html.twig' %}

{% block title %}Expériences | MyExperiences{% endblock %}

{% block body %}
    <section class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <h1 class="section-title mb-1">Catalogue des expériences</h1>
            <p class="text-muted mb-0">Filtrez par lieu, budget ou date pour trouver le bon créneau.</p>
        </div>
    </section>

    <section class="card app-card mb-4">
        <div class="card-body">
            <form class="row g-3 align-items-end" method="get">
                <div class="col-md-4">
                    <label class="form-label" for="location">Lieu</label>
                    <input class="form-control" type="text" id="location" name="location" value="{{ filters.location }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="maxPrice">Prix max</label>
                    <input class="form-control" type="number" step="0.01" id="maxPrice" name="maxPrice" value="{{ filters.maxPrice }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="date">Date</label>
                    <input class="form-control" type="date" id="date" name="date" value="{{ filters.date }}">
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" type="submit">Filtrer</button>
                </div>
            </form>
        </div>
    </section>

    <section class="row g-4">
        {% for experience in experiences %}
            <div class="col-md-6 col-xl-4">
                {% include 'partials/_experience_card.html.twig' with { experience: experience } %}
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-light border">Aucune expérience ne correspond à ces filtres.</div>
            </div>
        {% endfor %}
    </section>
{% endblock %}
