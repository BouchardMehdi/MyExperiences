<article class="card app-card h-100">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
                <span class="badge badge-soft mb-2">{{ experience.location }}</span>
                <h3 class="h5 mb-1">{{ experience.title }}</h3>
                <p class="text-muted small mb-0">Par {{ experience.organizer.fullName }}</p>
            </div>
            <span class="fw-semibold text-primary">{{ experience.price|number_format(2, ',', ' ') }} €</span>
        </div>
        <p class="text-muted">{{ experience.description|length > 120 ? experience.description|slice(0, 120) ~ '...' : experience.description }}</p>
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <small class="text-muted">{{ experience.duration }} min</small>
            <a class="btn btn-outline-primary btn-sm" href="{{ path('app_experience_show', {id: experience.id}) }}">Voir le détail</a>
        </div>
    </div>
</article>
